# Django core
SECRET_KEY=change-me
DEBUG=False

# Comma-separated hosts, e.g. 127.0.0.1,localhost,.onrender.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Optional comma-separated full origins, e.g. https://your-app.onrender.com
CSRF_TRUSTED_ORIGINS=

# Database URL examples:
# SQLite: sqlite:///db.sqlite3
# Postgres: postgres://user:password@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Cache backend options: db or locmem
CACHE_BACKEND=db
